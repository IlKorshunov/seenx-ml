@startuml 00_c4_l1_project_overview
!include style_c4_readable.puml

top to bottom direction
scale max 2200 width

skinparam defaultFontSize 30
skinparam ArrowFontSize 22

skinparam rectangle<<pipeline>> {
  BackgroundColor #FFCDD2
}

' ── акторы и источники (слева) ───────────────────────────────
rectangle "<b>Исследователь</b>\nзапускает пайплайн,\nзадаёт параметры запуска" as researcher <<input>>

rectangle "<b>Исходные данные</b>\nвидео, аудио,\nретеншн-кривые,\nметаданные" as raw <<input>>

rectangle "<b>YouTube Data API</b>\nканалы, плейлисты,\nкомментарии и реакции\nаудитории" as youtube <<input>>

' ── система-«чёрный ящик» (центр) ────────────────────────────
rectangle "<b>seenx-ml</b>\nсистема прогнозирования\nкривой удержания\nYouTube-видео" as system <<pipeline>>

' ── получатель отчёта (справа) ───────────────────────────────
rectangle "<b>Пользователь</b>\nполучает отчёт\nи использует прогнозы" as consumer <<input>>

' ── компактная раскладка для приложения ──────────────────────
researcher -[hidden]right-> raw
raw        -[hidden]right-> youtube
raw        -[hidden]down-> system
system     -[hidden]down-> consumer

' ── связи ────────────────────────────────────────────────────
researcher -down-> system : запускает пайплайн,\nпередаёт пути\nи конфигурацию
raw        -down-> system : файлы видео,\nаудио и retention
youtube    -down-> system : комментарии\nи метаданные

system -down-> consumer : отдаёт отчёт\n(прогнозы retention,\nсоветы для доработки видео,\nметрики)

legend bottom left
  |= Цвет |= Тип блока |
  | <back:#B9F6CA>     </back> | пользователь / источник данных |
  | <back:#FFCDD2>     </back> | система |
endlegend

@enduml
