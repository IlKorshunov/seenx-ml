@startuml 01_c4_container_system_architecture
!include style_c4_readable.puml

top to bottom direction
scale max 2200 width

skinparam defaultFontSize 36
skinparam ArrowFontSize 24
skinparam nodesep 80
skinparam ranksep 95
skinparam package {
  FontSize 30
}

' ── вход и выход пайплайна ───────────────────────────────────
rectangle "<b>Вход пайплайна</b>\nпараметры запуска,\nмедиафайлы,\nretention,\nметаданные" as input <<input>>

' ── укрупнённые контейнеры системы ───────────────────────────
package "seenx-ml" {

  rectangle "<b>CLI-запуск</b>\nкоординация этапов,\nпараметры запуска,\nконтроль статуса" as cli <<pipeline>>

  rectangle "<b>Сбор данных</b>\nзагрузка материалов,\nметаданных,\nкомментариев" as ingest <<pipeline>>

  rectangle "<b>Подготовка признаков</b>\nизвлечение,\nагрегация,\nнормализация,\nформирование датасета" as features <<component>>

  rectangle "<b>Кластеризация и настройка</b>\nгруппы видео,\nпоиск параметров,\nподготовка конфигураций" as tuning <<component>>

  rectangle "<b>Моделирование</b>\nобучение LSTM,\nTransformer,\nVideoMAE-варианта" as modeling <<component>>

  rectangle "<b>Анализ результатов</b>\nметрики,\nважность признаков,\nсводные отчёты" as analysis <<component>>
}

rectangle "<b>Артефакты</b>\nмодели, метрики,\nграфики, отчёты" as artifacts <<output>>

' ── вертикальный поток без пересечений ───────────────────────
input    -[hidden]down-> cli
cli      -[hidden]down-> ingest
ingest   -[hidden]down-> features
features -[hidden]down-> tuning
tuning   -[hidden]down-> modeling
modeling -[hidden]down-> analysis
analysis -[hidden]down-> artifacts

' ── основной поток ───────────────────────────────────────────
input    -down-> cli        : входные\nданные
cli      -down-> ingest     : запускает\nсбор
ingest   -down-> features   : данные\nпо видео
features -down-> tuning : таблица признаков\nи эмбеддинги
tuning   -down-> modeling : группы видео\nи параметры
modeling -down-> analysis   : модели\nи предсказания
analysis -down-> artifacts  : сохраняет\nрезультаты

legend bottom left
  |= Цвет |= Тип блока |
  | <back:#B9F6CA>     </back> | пользователи / источник данных |
  | <back:#FFCDD2>     </back> | оркестрация и сборка |
  | <back:#BBDEFB>     </back> | компонент обработки |
  | <back:#D6D6D6>     </back> | результат |
endlegend

@enduml
