@startuml 02_c4_l2_comment_collection
!include style_c4_readable.puml

top to bottom direction
scale max 1800 height

skinparam defaultFontSize 30
skinparam ArrowFontSize 22

rectangle "<b>Исследователь</b>\nзапускает экспорт,\nпередаёт параметры,\nконтролирует результат" as user <<input>>

rectangle "<b>CLI</b>\nпринимает параметры,\nзапускает экспорт,\nпроверяет выполнение" as cli <<pipeline>>

rectangle "<b>YouTube Data API</b>\nканал, плейлисты,\nметаданные,\nкомментарии" as youtube <<input>>

rectangle "<b>Экспорт</b>\nкомментарии и ответы,\nтаймкоды,\nметаданные видео" as export <<component>>

rectangle "<b>Сборка JSON</b>\nобъединяет метаданные,\nкомментарии,\nданные по видео" as merge <<pipeline>>

rectangle "<b>Хранилище</b>\nJSON-файлы\nс комментариями\nи метаданными" as store <<output>>

' ── компактный вертикальный порядок ──────────────────────────
user    -[hidden]down-> cli
cli     -[hidden]down-> youtube
youtube -[hidden]down-> export
export  -[hidden]down-> merge
merge   -[hidden]down-> store

user    -down-> cli     : запускает\nэкспорт
cli     -down-> youtube : параметры\nзапроса
youtube -down-> export  : данные\nYouTube
export  -down-> merge   : данные\nпо видео
merge   -down-> store   : запись\nJSON

legend bottom left
  |= Цвет |= Тип блока |
  | <back:#B9F6CA>     </back> | внешние данные / акторы |
  | <back:#FFCDD2>     </back> | оркестрация и сборка |
  | <back:#BBDEFB>     </back> | компонент сбора |
  | <back:#D6D6D6>     </back> | результат |
endlegend

@enduml