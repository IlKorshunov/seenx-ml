@startuml 08_c4_l2_model_architecture
!include style_c4_readable.puml

' ── входы по модальностям (верхний ряд) ──────────────────────
rectangle "<b>Visual embedding</b>\nVideoMAE / CLIP,\nвектор по секунде" as visual_in <<input>>
rectangle "<b>Audio embedding</b>\nCLAP / Wav2Vec2,\nвектор по секунде" as audio_in <<input>>
rectangle "<b>Text embedding</b>\nUSER2,\nвектор по секунде" as text_in <<input>>
rectangle "<b>Tabular features</b>\nпосекундные\nтабличные признаки" as tab_in <<input>>

' ── проекции к общей размерности d_model ─────────────────────
package "Проекции модальностей" {
  rectangle "<b>Visual projection</b>\nLinear → LayerNorm\n→ GELU → Dropout" as vp <<component>>
  rectangle "<b>Audio projection</b>\nLinear → LayerNorm\n→ GELU → Dropout" as ap <<component>>
  rectangle "<b>Text projection</b>\nLinear → LayerNorm\n→ GELU → Dropout" as tp <<component>>
  rectangle "<b>Tabular projection</b>\nLinear → LayerNorm\n→ GELU → Dropout" as tabp <<component>>
}

' ── слияние модальностей ─────────────────────────────────────
rectangle "<b>Fusion</b>\nconcat(visual, audio, text),\nLinear (3·d_model → d_model)" as fusion <<pipeline>>

' ── табличный гейт ───────────────────────────────────────────
rectangle "<b>Gate</b>\nh + σ(Linear([h ; tab_h])) ⊙ tab_h:\nтабличные признаки добавляют\nмодулированную поправку" as gate <<pipeline>>

' ── энкодер: две альтернативы (для сравнения архитектур) ─────
package "Encoder - альтернативы" {
  rectangle "<b>Transformer encoder</b>\nпозиционные кодировки,\npadding mask,\nself-attention" as enc_tr <<component>>
  rectangle "<b>BiLSTM encoder</b>\nрекуррентная сеть,\nдополнительная Linear-проекция" as enc_lstm <<component>>
}

' ── deviation head и опорная кривая ──────────────────────────
rectangle "<b>Baseline retention</b>\nопорная кривая\nпо обучающим видео" as baseline <<input>>

rectangle "<b>Deviation head</b>\nMLP предсказывает\nотклонение от baseline:\nδ · tanh(Linear(LN(h)))" as head <<pipeline>>

' ── выход ────────────────────────────────────────────────────
rectangle "<b>Predicted retention</b>\nbaseline + δ" as out <<output>>

' ── раскладка верхнего ряда входов ───────────────────────────
visual_in -[hidden]right-> audio_in
audio_in  -[hidden]right-> text_in
text_in   -[hidden]right-> tab_in

' ── раскладка проекций ───────────────────────────────────────
vp -[hidden]right-> ap
ap -[hidden]right-> tp
tp -[hidden]right-> tabp

' ── раскладка двух энкодеров ─────────────────────────────────
enc_tr -[hidden]right-> enc_lstm

' ── основные связи ───────────────────────────────────────────
visual_in -down-> vp : visual embedding\n(B,T,768)
audio_in  -down-> ap : audio embedding\n(B,T,512)
text_in   -down-> tp : text embedding\n(B,T,256)
tab_in    -down-> tabp : tabular features\n(B,T,F)

vp -down-> fusion : visual_h\n(B,T,d_model)
ap -down-> fusion : audio_h\n(B,T,d_model)
tp -down-> fusion : text_h\n(B,T,d_model)

fusion -down-> gate : h\nfused state
tabp   -down-> gate : tab_h\ntabular state

gate -down-> enc_tr : h_out\ngated state
gate -down-> enc_lstm : h_out\ngated state

enc_tr   -down-> head : encoded h\nTransformer
enc_lstm -down-> head : encoded h\nBiLSTM
baseline -right-> head : опорная\nкривая

head -down-> out : baseline + δ\nretention curve

legend bottom left
  |= Цвет |= Тип блока |
  | <back:#B9F6CA>     </back> | вход / опорная кривая |
  | <back:#FFCDD2>     </back> | сборка и преобразование |
  | <back:#BBDEFB>     </back> | компонент модели |
  | <back:#D6D6D6>     </back> | результат |
  | <back:#FFFFFF> h </back> | скрытое состояние модели |
endlegend

@enduml
