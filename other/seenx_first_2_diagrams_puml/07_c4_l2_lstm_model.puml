@startuml 07_c4_l2_lstm_model
!include style_c4_readable.puml

title LSTM-модель удержания — C4 L2

rectangle "Входные данные\nпосекундные признаки,\nэмбеддинги visual/audio/text,\nмаска padding" as input <<input>>

package "MultimodalRetentionLSTM" {

  rectangle "Проекции модальностей\nvisual, audio, text\nприводятся к общей размерности" as proj <<pipeline>>

  package "Слияние входов" {
    rectangle "Fusion\nконкатенация модальностей,\nлинейная проекция" as fusion <<component>>

    rectangle "Tabular gate\nтабличные признаки\nмодулируют скрытое состояние" as gate <<component>>
  }

  rectangle "Локальный контекст\nопциональные Conv-блоки\nс ядрами 3, 5, 7" as conv1 <<component>>

  rectangle "Residual BiLSTM\nдвунаправленная LSTM,\nучёт временной динамики" as lstm <<component>>

  rectangle "Нормализация\nresidual projection,\nLayerNorm,\nопциональный post-conv" as norm <<pipeline>>

  rectangle "Temporal attention\nвзвешивает вклад\nсекунд видео" as attn <<component>>

  rectangle "Deviation head\nMLP предсказывает\nотклонение от baseline" as head <<pipeline>>
}

rectangle "Baseline retention\nопорная кривая\nпо обучающим видео" as baseline <<input>>

rectangle "Результат\nпредсказанная\nretention-кривая" as output <<output>>

' ── раскладка fusion/gate ─────────────────────────────────────
fusion -[hidden]right-> gate

' ── основной поток ────────────────────────────────────────────
input -down-> proj : передаёт\nмодальности
proj -down-> fusion : projected\nembeddings
fusion -right-> gate : скрытое\nсостояние
gate -down-> conv1 : gated\nsequence
conv1 -down-> lstm : локальные\nзависимости
lstm -down-> norm : временное\nпредставление
norm -down-> attn : нормализованные\nсостояния
attn -down-> head : контекст\nпо времени
baseline -right-> head : опорная\nкривая
head -down-> output : baseline +\nотклонение

legend bottom left
  |= Цвет |= Тип блока |
  | <back:#F1F8E9><color:#2E7D32>████</color></back> | входные данные |
  | <back:#FFF8F8><color:#C62828>████</color></back> | оркестрация и сборка |
  | <back:#F7FBFF><color:#1565C0>████</color></back> | компонент модели |
  | <back:#F5F5F5><color:#6D6D6D>████</color></back> | результат |
end legend

@enduml
