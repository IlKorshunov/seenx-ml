@startuml 06_c4_l3_analysis_tuning
!include style_c4_readable.puml

top to bottom direction
scale max 1800 height

skinparam defaultFontSize 30
skinparam ArrowFontSize 22

rectangle "<b>Входные данные</b>\nтаблицы признаков,\nэмбеддинги,\nвеса моделей,\nметрики" as input <<input>>

rectangle "<b>Оркестратор анализа</b>\nзапуск методов,\nконтроль расчётов,\nсборка отчёта" as orchestrator <<pipeline>>

package "Методы анализа признаков" {

  rectangle "<b>Статистические оценки</b>\nSpearman, Pearson,\nmutual information" as stat <<component>>

  rectangle "<b>Модельные оценки</b>\nCatBoost importance,\nPermutation,\nSHAP" as model <<component>>
}

rectangle "<b>Сводная сборка</b>\nmaster ranking,\nsummary report,\nсогласование оценок" as merge <<pipeline>>

rectangle "<b>Результат</b>\nрейтинги признаков,\nграфики важности,\nсводные отчёты" as output <<output>>

' ── компактная раскладка ─────────────────────────────────────
input -[hidden]down-> orchestrator
stat -[hidden]right-> model
orchestrator -[hidden]down-> model
model -[hidden]down-> merge
merge -[hidden]down-> output

' ── основной поток ────────────────────────────────────────────
input -down-> orchestrator : передаёт\nданные и модели

orchestrator -down-> stat : анализ
orchestrator -down-> model : анализ

stat -down-> merge : оценки
model -down-> merge : оценки

merge -down-> output : запись\nрезультатов

legend bottom left
  |= Цвет |= Тип блока |
  | <back:#B9F6CA>     </back> | входные данные |
  | <back:#FFCDD2>     </back> | оркестрация и сборка |
  | <back:#BBDEFB>     </back> | компонент анализа |
  | <back:#D6D6D6>     </back> | результат |
endlegend

@enduml
